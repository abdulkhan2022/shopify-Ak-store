{% liquid
  assign tab_count = 0
  for block in section.blocks
    if block.type == 'tab'
      assign tab_count = tab_count | plus: 1
    endif
  endfor

  assign marquee_count = 0
  for block in section.blocks
    if block.type == 'marquee_item'
      assign marquee_count = marquee_count | plus: 1
    endif
  endfor
%}

{% if tab_count > 0 %}
  <script src="{{ 'concern-tabs-showcase.js' | asset_url }}" type="module" fetchpriority="low"></script>
{% endif %}

{% render 'buy-buttons-styles' %}

<div
  class="concern-tabs-showcase section section--full-width spacing-style"
  id="shopify-section-{{ section.id }}"
  style="
    {% render 'spacing-padding', settings: section.settings %}
    --showcase-progress-duration: {{ section.settings.autoplay_speed }}s;
  "
>
  <div class="concern-tabs-showcase__surface color-{{ section.settings.color_scheme }}">
    <div class="concern-tabs-showcase__inner">
    <div class="concern-tabs-showcase__ticker" role="region" aria-label="{{ section.settings.ticker_aria_label | escape }}">
      <span class="concern-tabs-showcase__ticker-left">
        {{ section.settings.ticker_left_text | escape }}
      </span>
      <div class="concern-tabs-showcase__ticker-marquee" {% if marquee_count == 0 %}data-marquee-fallback{% endif %}>
        <div class="concern-tabs-showcase__ticker-track">
          {% if marquee_count > 0 %}
            {% for block in section.blocks %}
              {% if block.type == 'marquee_item' %}
                <span class="concern-tabs-showcase__ticker-item" {{ block.shopify_attributes }}>
                  {{ block.settings.text | escape }}
                </span>
              {% endif %}
            {% endfor %}
            {% for block in section.blocks %}
              {% if block.type == 'marquee_item' %}
                <span class="concern-tabs-showcase__ticker-item" aria-hidden="true">
                  {{ block.settings.text | escape }}
                </span>
              {% endif %}
            {% endfor %}
          {% else %}
            {% assign quotes = section.settings.ticker_fallback | split: '
' %}
            {% for line in quotes %}
              {% assign q = line | strip %}
              {% if q != blank %}
                <span class="concern-tabs-showcase__ticker-item">{{ q | escape }}</span>
              {% endif %}
            {% endfor %}
            {% for line in quotes %}
              {% assign q = line | strip %}
              {% if q != blank %}
                <span class="concern-tabs-showcase__ticker-item" aria-hidden="true">{{ q | escape }}</span>
              {% endif %}
            {% endfor %}
          {% endif %}
        </div>
      </div>
    </div>

    {% if section.settings.pill_label != blank %}
      <div class="concern-tabs-showcase__pill-wrap">
        <span class="concern-tabs-showcase__pill">{{ section.settings.pill_label | escape }}</span>
      </div>
    {% endif %}

    {% if section.settings.heading != blank %}
      <div class="concern-tabs-showcase__heading rte">
        {{ section.settings.heading }}
      </div>
    {% endif %}

    {% if tab_count > 0 %}
      <concern-tabs-showcase
        class="concern-tabs-showcase__shell"
        {% if tab_count > 1 and section.settings.autoplay %}
          autoplay
        {% endif %}
        data-autoplay-ms="{{ section.settings.autoplay_speed | times: 1000 }}"
        data-testid="concern-tabs-showcase"
      >
        {% if tab_count > 1 %}
          <div
            class="concern-tabs-showcase__tabs concern-tabs-showcase__tabs--center"
            role="tablist"
            aria-label="{{ section.settings.tabs_aria_label | escape }}"
          >
            {% assign tab_index = 0 %}
            {% for block in section.blocks %}
              {% if block.type != 'tab' %}
                {% continue %}
              {% endif %}
              <button
                type="button"
                class="concern-tabs-showcase__tab"
                data-showcase-tab
                data-index="{{ tab_index }}"
                role="tab"
                aria-selected="{% if tab_index == 0 %}true{% else %}false{% endif %}"
                aria-controls="concern-showcase-panel-{{ section.id }}-{{ tab_index }}"
                id="concern-showcase-tab-{{ section.id }}-{{ tab_index }}"
              >
                <span class="concern-tabs-showcase__tab-label">
                  {{ block.settings.tab_label | default: block.settings.heading_bold | strip_html | truncate: 28 }}
                </span>
              </button>
              {% assign tab_index = tab_index | plus: 1 %}
            {% endfor %}
          </div>
        {% endif %}

        <div class="concern-tabs-showcase__layout">
          <div
            class="concern-tabs-showcase__hero-viewport"
            style="--showcase-hero-radius: {{ section.settings.hero_radius }}px;"
          >
            {% assign tab_index = 0 %}
            {% for block in section.blocks %}
              {% if block.type != 'tab' %}
                {% continue %}
              {% endif %}
              {% liquid
                assign is_active = false
                if tab_index == 0
                  assign is_active = true
                endif
              %}
              <article
                class="concern-tabs-showcase__slide"
                id="concern-showcase-panel-{{ section.id }}-{{ tab_index }}"
                data-showcase-slide
                {% if is_active %}
                  data-active="true"
                  aria-hidden="false"
                {% else %}
                  data-active="false"
                  aria-hidden="true"
                {% endif %}
                {{ block.shopify_attributes }}
              >
                <div class="concern-tabs-showcase__slide-media">
                  {% if block.settings.media_type == 'video' and block.settings.background_video != blank %}
                    {{
                      block.settings.background_video
                      | video_tag:
                        class: 'concern-tabs-showcase__slide-video',
                        muted: true,
                        loop: true,
                        controls: false,
                        playsinline: true,
                        preload: 'metadata'
                    }}
                    <button
                      type="button"
                      class="concern-tabs-showcase__play"
                      data-hero-video-play
                      aria-label="Play video"
                    >
                      <span class="svg-wrapper">
                        {{- 'icon-play.svg' | inline_asset_content -}}
                      </span>
                    </button>
                  {% elsif block.settings.background_image != blank %}
                    {{
                      block.settings.background_image
                      | image_url: width: 1600
                      | image_tag:
                        widths: '400, 700, 1000, 1400, 1600',
                        sizes: '(min-width: 990px) 55vw, 100vw',
                        class: 'concern-tabs-showcase__slide-img',
                        loading: 'lazy',
                        alt: block.settings.background_image.alt
                    }}
                  {% else %}
                    {{ 'hero-apparel-1' | placeholder_svg_tag: 'concern-tabs-showcase__slide-img concern-tabs-showcase__slide-img--placeholder' }}
                  {% endif %}
                </div>
                <div class="concern-tabs-showcase__slide-overlay"></div>
                <div class="concern-tabs-showcase__slide-content">
                  <div class="concern-tabs-showcase__slide-copy">
                    {% if block.settings.heading_bold != blank %}
                      <h2 class="concern-tabs-showcase__slide-heading-bold">{{ block.settings.heading_bold }}</h2>
                    {% endif %}
                    {% if block.settings.heading_italic != blank %}
                      <p class="concern-tabs-showcase__slide-heading-italic">{{ block.settings.heading_italic }}</p>
                    {% endif %}
                    {% if block.settings.description != blank %}
                      <p class="concern-tabs-showcase__slide-desc">{{ block.settings.description }}</p>
                    {% endif %}
                    {% if block.settings.button_label != blank and block.settings.button_link != blank %}
                      <a class="concern-tabs-showcase__slide-cta" href="{{ block.settings.button_link }}">
                        <span>{{ block.settings.button_label }}</span>
                        <span class="svg-wrapper" aria-hidden="true">
                          {{ 'icon-arrow.svg' | inline_asset_content }}
                        </span>
                      </a>
                    {% endif %}
                  </div>
                </div>
              </article>
              {% assign tab_index = tab_index | plus: 1 %}
            {% endfor %}
          </div>

          <div class="concern-tabs-showcase__products">
            {% render 'concern-showcase-product-cell',
              product: section.settings.product_1,
              section: section,
              cell_index: 1
            %}
            {% render 'concern-showcase-product-cell',
              product: section.settings.product_2,
              section: section,
              cell_index: 2
            %}
            {% render 'concern-showcase-product-cell',
              product: section.settings.product_3,
              section: section,
              cell_index: 3
            %}
            {% render 'concern-showcase-product-cell',
              product: section.settings.product_4,
              section: section,
              cell_index: 4
            %}
          </div>
        </div>
      </concern-tabs-showcase>
    {% else %}
      <div class="concern-tabs-showcase__layout concern-tabs-showcase__layout--empty">
        <div class="concern-tabs-showcase__hero-viewport" style="--showcase-hero-radius: {{ section.settings.hero_radius }}px;">
          <article class="concern-tabs-showcase__slide" data-showcase-slide data-active="true" aria-hidden="false">
            <div class="concern-tabs-showcase__slide-media">
              {{ 'hero-apparel-1' | placeholder_svg_tag: 'concern-tabs-showcase__slide-img concern-tabs-showcase__slide-img--placeholder' }}
            </div>
            <div class="concern-tabs-showcase__slide-overlay"></div>
            <div class="concern-tabs-showcase__slide-content">
              <h2 class="concern-tabs-showcase__slide-heading-bold">{{ section.settings.empty_heading | escape }}</h2>
              <p class="concern-tabs-showcase__slide-desc">{{ section.settings.empty_text | escape }}</p>
            </div>
          </article>
        </div>
        <div class="concern-tabs-showcase__products">
          {% render 'concern-showcase-product-cell',
            product: section.settings.product_1,
            section: section,
            cell_index: 1
          %}
          {% render 'concern-showcase-product-cell',
            product: section.settings.product_2,
            section: section,
            cell_index: 2
          %}
          {% render 'concern-showcase-product-cell',
            product: section.settings.product_3,
            section: section,
            cell_index: 3
          %}
          {% render 'concern-showcase-product-cell',
            product: section.settings.product_4,
            section: section,
            cell_index: 4
          %}
        </div>
      </div>
    {% endif %}
    </div>
  </div>
</div>

{% stylesheet %}
  .concern-tabs-showcase {
    width: 100%;
    max-width: none;
    margin-inline: 0;
  }

  .concern-tabs-showcase__surface {
    border-radius: 0;
    padding-block: clamp(20px, 4vw, 40px);
    padding-inline: max(var(--page-margin, 1.25rem), 1.25rem);
    background: linear-gradient(180deg, #1b4332 0%, #2d6a4f 42%, #6bbf59 88%, #b8e986 100%);
    color: #fff;
  }

  .concern-tabs-showcase__inner {
    width: 100%;
    max-width: 1440px;
    margin-inline: auto;
  }

  .concern-tabs-showcase__ticker {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: clamp(24px, 6vw, 120px);
    padding-block-end: 16px;
    margin-block-end: 12px;
    border-bottom: 1px solid rgb(255 255 255 / 25%);
    font-size: 0.8125rem;
  }

  .concern-tabs-showcase__ticker-left {
    flex: 0 0 auto;
    white-space: nowrap;
    font-weight: 600;
    letter-spacing: 0.02em;
  }

  .concern-tabs-showcase__ticker-marquee {
    flex: 0 1 min(70%, 920px);
    margin-left: auto;
    min-width: 0;
    overflow: hidden;
    mask-image: linear-gradient(90deg, transparent, #000 8%, #000 92%, transparent);
  }

  .concern-tabs-showcase__ticker-track {
    display: flex;
    width: max-content;
    gap: 2rem;
    animation: concern-showcase-ticker 32s linear infinite;
  }

  @media (prefers-reduced-motion: reduce) {
    .concern-tabs-showcase__ticker-track {
      animation: none;
      flex-wrap: wrap;
      width: auto;
      white-space: normal;
    }
  }

  @keyframes concern-showcase-ticker {
    to {
      transform: translate3d(-50%, 0, 0);
    }
  }

  .concern-tabs-showcase__ticker-item {
    white-space: nowrap;
    opacity: 0.95;
  }

  .concern-tabs-showcase__pill-wrap {
    display: flex;
    justify-content: center;
    margin-block-start: 90px;
    margin-block-end: 16px;
  }

  .concern-tabs-showcase__pill {
    display: inline-flex;
    align-items: center;
    padding: 8px 18px;
    border-radius: 999px;
    border: 1px solid rgb(255 255 255 / 85%);
    color: #fff;
    font-size: 0.875rem;
    font-weight: 500;
    letter-spacing: 0.02em;
  }

  .concern-tabs-showcase__heading {
    text-align: center;
    max-width: 56rem;
    margin-inline: auto;
    margin-block-end: clamp(12px, 2.5vw, 20px);
    font-size: clamp(1.25rem, 2.4vw, 2rem);
    line-height: 1.25;
    color: #fff;
  }

  .concern-tabs-showcase__heading em,
  .concern-tabs-showcase__heading i {
    font-family: var(--font-accent--family, var(--font-heading--family));
    font-style: italic;
  }

  .concern-tabs-showcase__shell {
    display: flex;
    flex-direction: column;
    gap: clamp(8px, 2vw, 16px);
    width: 100%;
    min-height: 0;
  }

  .concern-tabs-showcase__layout {
    display: grid;
    gap: clamp(16px, 3vw, 28px);
    align-items: stretch;
    width: 100%;
  }

  @media screen and (min-width: 990px) {
    .concern-tabs-showcase__layout {
      grid-template-columns: minmax(0, 1.05fr) minmax(0, 0.95fr);
    }
  }

  .concern-tabs-showcase__layout--empty {
    margin-top: clamp(8px, 2vw, 16px);
  }

  .concern-tabs-showcase__hero-viewport {
    position: relative;
    min-height: clamp(320px, 52vw, 520px);
    border-radius: var(--showcase-hero-radius, 16px);
    overflow: hidden;
    background: rgb(0 0 0 / 25%);
  }

  .concern-tabs-showcase__slide {
    position: absolute;
    inset: 0;
    opacity: 0;
    visibility: hidden;
    transition: opacity 360ms ease;
  }

  .concern-tabs-showcase__slide[data-active='true'] {
    opacity: 1;
    visibility: visible;
  }

  .concern-tabs-showcase__slide-media,
  .concern-tabs-showcase__slide-img,
  .concern-tabs-showcase__slide-video {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }

  .concern-tabs-showcase__slide-img,
  .concern-tabs-showcase__slide-video {
    object-fit: cover;
  }

  .concern-tabs-showcase__slide-img--placeholder {
    opacity: 0.35;
  }

  .concern-tabs-showcase__play {
    position: absolute;
    top: 16px;
    right: 16px;
    z-index: 2;
    width: 48px;
    height: 48px;
    border-radius: 50%;
    border: 0;
    display: grid;
    place-items: center;
    background: rgb(255 255 255 / 95%);
    color: #111;
    cursor: pointer;
    box-shadow: 0 6px 20px rgb(0 0 0 / 18%);
  }

  .concern-tabs-showcase__play .svg-wrapper {
    width: 22px;
    height: 22px;
    display: flex;
  }

  .concern-tabs-showcase__slide-overlay {
    position: absolute;
    inset: 0;
    z-index: 0;
    background: linear-gradient(180deg, rgb(0 0 0 / 15%) 0%, rgb(0 0 0 / 55%) 100%);
    pointer-events: none;
  }

  .concern-tabs-showcase__slide-content {
    position: absolute;
    inset: 0;
    z-index: 1;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    align-items: flex-start;
    padding: 0;
    color: #fff;
  }

  .concern-tabs-showcase__slide-copy {
    width: 100%;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 10px;
    padding: clamp(14px, 2vw, 18px) clamp(14px, 2vw, 20px);
    border-radius: 16px;
    background: rgb(8 11 16 / 38%);
    backdrop-filter: blur(2px);
  }

  .concern-tabs-showcase__slide-heading-bold {
    margin: 0;
    font-family: var(--font-heading--family);
    font-size: clamp(1.35rem, 2.5vw, 2.25rem);
    line-height: 1.1;
    color: #fff;
  }

  .concern-tabs-showcase__slide-heading-italic {
    margin: 0;
    font-family: var(--font-accent--family, var(--font-heading--family));
    font-style: italic;
    font-size: clamp(1.1rem, 2vw, 1.65rem);
    line-height: 1.2;
    color: rgb(255 255 255 / 95%);
  }

  .concern-tabs-showcase__slide-desc {
    margin: 0;
    max-width: 42ch;
    font-size: 0.9375rem;
    line-height: 1.55;
    color: rgb(255 255 255 / 88%);
  }

  .concern-tabs-showcase__slide-cta {
    margin-top: 6px;
    display: inline-flex;
    align-items: center;
    gap: 10px;
    min-height: var(--minimum-touch-target, 44px);
    padding: 10px 20px;
    border-radius: 999px;
    background: #fff;
    color: #000;
    text-decoration: none;
    font-weight: 600;
    line-height: 1;
  }

  .concern-tabs-showcase__slide-cta:hover {
    background: rgb(255 255 255 / 92%);
  }

  .concern-tabs-showcase__slide-cta .svg-wrapper {
    width: 14px;
    height: 14px;
    display: inline-flex;
  }

  .concern-tabs-showcase__tabs--center {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    align-items: flex-end;
    gap: clamp(1.25rem, 4vw, 2.75rem);
    margin-block: 0 clamp(16px, 3vw, 28px);
    padding-block-start: 4px;
  }

  .concern-tabs-showcase__tabs--center .concern-tabs-showcase__tab {
    appearance: none;
    margin: 0;
    padding: 0.4rem 0.15rem 0.65rem;
    border: 0;
    border-bottom: 2px solid rgb(255 255 255 / 38%);
    border-radius: 0;
    background: transparent;
    color: #fff;
    cursor: pointer;
    font: inherit;
    display: inline-flex;
    flex-direction: column;
    align-items: center;
    min-width: 3.5rem;
    text-align: center;
    transition:
      border-color 180ms ease,
      border-width 180ms ease,
      opacity 180ms ease;
  }

  .concern-tabs-showcase__tabs--center .concern-tabs-showcase__tab:hover {
    border-bottom-color: rgb(255 255 255 / 65%);
  }

  .concern-tabs-showcase__tabs--center .concern-tabs-showcase__tab[aria-selected='true'] {
    border-bottom-width: 3px;
    border-bottom-color: #fff;
    opacity: 1;
  }

  .concern-tabs-showcase__tabs--center .concern-tabs-showcase__tab-label {
    font-size: clamp(0.9375rem, 1.6vw, 1.0625rem);
    line-height: 1.3;
    white-space: nowrap;
  }

  @media screen and (max-width: 989px) {
    .concern-tabs-showcase__hero-viewport {
      min-height: min(68vh, 480px);
    }
  }

  .concern-tabs-showcase__products {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: clamp(14px, 2.2vw, 22px);
    align-content: start;
  }

  .concern-tabs-showcase__product-cell {
    position: relative;
    display: flex;
    flex-direction: column;
    border-radius: 0;
    background: transparent;
    color: #fff;
    overflow: visible;
    min-height: 100%;
  }

  .concern-tabs-showcase__product-media {
    position: relative;
    aspect-ratio: 1;
    border-radius: 8px;
    background: #e8e6e0;
    overflow: hidden;
  }

  .concern-tabs-showcase__product-media-link {
    position: absolute;
    inset: 0;
    z-index: 1;
  }

  .concern-tabs-showcase__product-img,
  .concern-tabs-showcase__product-placeholder {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .concern-tabs-showcase__product-body {
    position: relative;
    z-index: 2;
    display: flex;
    flex-direction: column;
    gap: 4px;
    padding: 8px 0 0;
    flex: 1 1 auto;
  }

  .concern-tabs-showcase__product-heading {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 12px;
  }

  .concern-tabs-showcase__product-title {
    margin: 0;
    font-size: 18px;
    line-height: 1.5;
    font-weight: 400;
    letter-spacing: 0;
    color: #fff;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    flex: 1 1 auto;
    min-width: 0;
  }

  .concern-tabs-showcase__product-title-link {
    color: inherit;
    text-decoration: none;
  }

  .concern-tabs-showcase__product-title-link:hover {
    text-decoration: underline;
  }

  .concern-tabs-showcase__product-meta {
    margin-top: 2px;
  }

  .concern-tabs-showcase__product-price {
    flex-shrink: 0;
  }

  .concern-tabs-showcase__product-price .price,
  .concern-tabs-showcase__product-price .price-item {
    font-size: 18px;
    line-height: 1.5;
    font-weight: 400;
    letter-spacing: 0;
    color: #fff;
  }

  .concern-tabs-showcase__product-price .price--on-sale .price-item--regular,
  .concern-tabs-showcase__product-price .price__badge-sale,
  .concern-tabs-showcase__product-price .price__badge-sold-out,
  .concern-tabs-showcase__product-price .price__tax {
    display: none;
  }

  .concern-tabs-showcase__product-rating {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    color: rgb(255 255 255 / 92%);
    font-weight: 400;
    font-size: 0.9375rem;
  }

  .concern-tabs-showcase__product-form-wrap {
    margin-top: auto;
    padding-top: 6px;
  }

  .concern-tabs-showcase__product-cta {
    width: 100%;
    justify-content: center;
    border-radius: 999px;
    font-weight: 500;
    font-size: 0.9375rem;
    min-height: 48px;
    padding: 12px 24px;
    transition: all 200ms ease;
    background: transparent !important;
    color: #fff !important;
    border: 1px solid #fff !important;
  }

  .concern-tabs-showcase__product-cta--light {
    background: transparent !important;
    color: #fff !important;
    border: 1px solid #fff !important;
  }

  .concern-tabs-showcase__product-cta--dark {
    background: transparent !important;
    color: #fff !important;
    border: 1px solid #fff !important;
  }

  .concern-tabs-showcase__product-cta:hover,
  .concern-tabs-showcase__product-cta--light:hover,
  .concern-tabs-showcase__product-cta--dark:hover {
    background: #fff !important;
    color: #111 !important;
    border-color: #fff !important;
  }

  .concern-tabs-showcase__product-cta:hover .add-to-cart-icon svg,
  .concern-tabs-showcase__product-cta--light:hover .add-to-cart-icon svg,
  .concern-tabs-showcase__product-cta--dark:hover .add-to-cart-icon svg {
    color: #111;
  }

  .concern-tabs-showcase__product-cta--dark .add-to-cart-icon svg {
    color: #fff;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:names.concern_tabs_showcase",
  "tag": "section",
  "class": "concern-tabs-showcase-section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "max_blocks": 24,
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
