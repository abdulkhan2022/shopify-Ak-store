
{% liquid
  assign s = section.settings
  assign card_bg = s.card_background
  assign page_bg = s.page_background
  assign radius = s.card_border_radius
  assign pad = s.card_padding
  assign logo_href = routes.root_url
  if s.logo_link != blank
    assign logo_href = s.logo_link
  endif
%}

<div
  class="footer-mega-card-section spacing-style{% if s.gradient_color_end != blank %} footer-mega-card-section--gradient{% endif %}"
  style="
    --fmc-page-bg: {{ page_bg }};
    {% if s.gradient_color_end != blank %}--fmc-page-bg-2: {{ s.gradient_color_end }};{% endif %}
    --fmc-card-bg: {{ card_bg }};
    --fmc-card-radius: {{ radius }}px;
    --fmc-card-pad: {{ pad }}px;
    --fmc-divider: {{ s.divider_color }};
    --fmc-column-gap: {{ s.column_gap }}px;
    {% render 'spacing-style', settings: s %}
  "
  {{ section.shopify_attributes }}
>
  <div class="footer-mega-card-section__canvas section section--{{ s.section_width }}">
    <div class="footer-mega-card">
      <div class="footer-mega-card__top">
        <div class="footer-mega-card__logo">
          {% if s.logo_image != blank %}
            <a class="footer-mega-card__logo-link" href="{{ logo_href }}">
              {{
                s.logo_image
                | image_url: width: 600
                | image_tag:
                  widths: '180, 360, 480, 600',
                  class: 'footer-mega-card__logo-img',
                  alt: s.logo_image.alt | default: shop.name,
                  loading: 'lazy'
              }}
            </a>
          {% elsif s.logo_text != blank %}
            <a class="footer-mega-card__logo-text" href="{{ logo_href }}">
              {{ s.logo_text | escape }}
            </a>
          {% else %}
            <a class="footer-mega-card__logo-text footer-mega-card__logo-text--fallback" href="{{ routes.root_url }}">
              {{ shop.name | escape }}
            </a>
          {% endif %}
        </div>

        <div class="footer-mega-card__columns">
          {% for block in section.blocks %}
            {% case block.type %}
              {% when 'column' %}
                <div class="footer-mega-card__column" {{ block.shopify_attributes }}>
                  {% if block.settings.heading != blank %}
                    <p class="footer-mega-card__column-heading">{{ block.settings.heading | escape }}</p>
                  {% endif %}
                  {% if block.settings.menu != blank %}
                    <nav aria-label="{{ block.settings.heading | default: block.settings.menu.title | escape }}">
                      <ul class="footer-mega-card__link-list list-unstyled">
                        {% for link in block.settings.menu.links %}
                          <li>
                            <a href="{{ link.url }}">{{ link.title | escape }}</a>
                          </li>
                        {% endfor %}
                      </ul>
                    </nav>
                  {% elsif request.design_mode %}
                    <p class="footer-mega-card__placeholder">Select a menu for this column.</p>
                  {% endif %}
                </div>
            {% endcase %}
          {% endfor %}
        </div>
      </div>

      <hr class="footer-mega-card__divider" aria-hidden="true">

      <div class="footer-mega-card__bottom">
        <div class="footer-mega-card__copyright">
          {% if s.copyright_custom != blank %}
            {{ s.copyright_custom }}
          {% else %}
            <p class="footer-mega-card__copyright-plain">
              &copy; {{ 'now' | date: '%Y' }} {{ shop.name | escape }}. All rights reserved.
            </p>
          {% endif %}
        </div>

        <div class="footer-mega-card__legal">
          {% if s.privacy_label != blank and s.privacy_url != blank %}
            <a href="{{ s.privacy_url }}">{{ s.privacy_label | escape }}</a>
          {% endif %}
          {% if s.terms_label != blank and s.terms_url != blank %}
            <a href="{{ s.terms_url }}">{{ s.terms_label | escape }}</a>
          {% endif %}
          {% if s.cookies_label != blank and s.cookies_url != blank %}
            <a href="{{ s.cookies_url }}">{{ s.cookies_label | escape }}</a>
          {% endif %}
        </div>

        <div class="footer-mega-card__social">
          {% if s.facebook_url != blank %}
            <a
              class="footer-mega-card__social-link"
              href="{{ s.facebook_url }}"
              target="_blank"
              rel="noopener noreferrer"
              aria-label="Facebook"
            >
              <svg class="footer-mega-card__social-icon" viewBox="0 0 20 20" aria-hidden="true" focusable="false" xmlns="http://www.w3.org/2000/svg">
                {%- render 'icon', icon: 'facebook' -%}
              </svg>
            </a>
          {% endif %}
          {% if s.instagram_url != blank %}
            <a
              class="footer-mega-card__social-link"
              href="{{ s.instagram_url }}"
              target="_blank"
              rel="noopener noreferrer"
              aria-label="Instagram"
            >
              <svg class="footer-mega-card__social-icon" viewBox="0 0 20 20" aria-hidden="true" focusable="false" xmlns="http://www.w3.org/2000/svg">
                {%- render 'icon', icon: 'instagram' -%}
              </svg>
            </a>
          {% endif %}
          {% if s.twitter_url != blank %}
            <a
              class="footer-mega-card__social-link"
              href="{{ s.twitter_url }}"
              target="_blank"
              rel="noopener noreferrer"
              aria-label="X"
            >
              <svg class="footer-mega-card__social-icon" viewBox="0 0 20 20" aria-hidden="true" focusable="false" xmlns="http://www.w3.org/2000/svg">
                {%- render 'icon', icon: 'twitter' -%}
              </svg>
            </a>
          {% endif %}
          {% if s.linkedin_url != blank %}
            <a
              class="footer-mega-card__social-link"
              href="{{ s.linkedin_url }}"
              target="_blank"
              rel="noopener noreferrer"
              aria-label="LinkedIn"
            >
              <svg class="footer-mega-card__social-icon" viewBox="0 0 20 20" aria-hidden="true" focusable="false" xmlns="http://www.w3.org/2000/svg">
                {%- render 'icon', icon: 'linkedin' -%}
              </svg>
            </a>
          {% endif %}
          {% if s.youtube_url != blank %}
            <a
              class="footer-mega-card__social-link"
              href="{{ s.youtube_url }}"
              target="_blank"
              rel="noopener noreferrer"
              aria-label="YouTube"
            >
              <svg class="footer-mega-card__social-icon" viewBox="0 0 20 20" aria-hidden="true" focusable="false" xmlns="http://www.w3.org/2000/svg">
                {%- render 'icon', icon: 'youtube' -%}
              </svg>
            </a>
          {% endif %}
        </div>
      </div>
    </div>
  </div>
</div>

{% stylesheet %}
  .footer-mega-card-section {
    background: var(--fmc-page-bg);
  }

  .footer-mega-card-section--gradient {
    background: linear-gradient(135deg, var(--fmc-page-bg) 0%, var(--fmc-page-bg-2) 100%);
  }

  .footer-mega-card__copyright-plain {
    margin: 0;
  }

  .footer-mega-card__copyright :first-child {
    margin-top: 0;
  }

  .footer-mega-card__copyright :last-child {
    margin-bottom: 0;
  }

  .footer-mega-card-section__canvas {
    padding-inline: var(--padding-inline-start, 1.5rem) var(--padding-inline-end, 1.5rem);
  }

  .footer-mega-card {
    background: var(--fmc-card-bg);
    border-radius: var(--fmc-card-radius);
    padding: var(--fmc-card-pad);
    color: #111;
    max-width: 100%;
  }

  .footer-mega-card__top {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  @media screen and (min-width: 990px) {
    .footer-mega-card__top {
      flex-direction: row;
      align-items: flex-start;
      gap: 3rem;
    }
  }

  .footer-mega-card__logo {
    flex-shrink: 0;
  }

  .footer-mega-card__logo-img {
    display: block;
    max-width: 160px;
    height: auto;
  }

  .footer-mega-card__logo-text {
    font-family: var(--font-heading--family);
    font-size: clamp(1.75rem, 4vw, 2.25rem);
    font-weight: 500;
    text-decoration: none;
    color: inherit;
  }

  .footer-mega-card__logo-text--fallback {
    font-family: var(--font-body--family);
    font-weight: 600;
  }

  .footer-mega-card__columns {
    flex: 1;
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--fmc-column-gap);
  }

  @media screen and (min-width: 600px) {
    .footer-mega-card__columns {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media screen and (min-width: 990px) {
    .footer-mega-card__columns {
      grid-template-columns: repeat(auto-fit, minmax(120px, 1fr));
    }
  }

  .footer-mega-card__column-heading {
    margin: 0 0 0.75rem;
    font-size: 0.95rem;
    font-weight: 700;
    font-family: var(--font-body--family);
  }

  .footer-mega-card__link-list {
    margin: 0;
    padding: 0;
  }

  .footer-mega-card__link-list li + li {
    margin-top: 0.5rem;
  }

  .footer-mega-card__link-list a {
    font-size: 0.9rem;
    text-decoration: none;
    color: inherit;
    opacity: 0.9;
  }

  .footer-mega-card__link-list a:hover {
    opacity: 1;
    text-decoration: underline;
  }

  .footer-mega-card__placeholder {
    margin: 0;
    font-size: 0.85rem;
    opacity: 0.55;
    font-style: italic;
  }

  .footer-mega-card__divider {
    border: 0;
    border-top: 1px solid var(--fmc-divider);
    margin: 2rem 0 1.5rem;
  }

  .footer-mega-card__bottom {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
    text-align: center;
    font-size: 0.75rem;
    font-family: var(--font-body--family);
  }

  @media screen and (min-width: 990px) {
    .footer-mega-card__bottom {
      flex-direction: row;
      flex-wrap: wrap;
      justify-content: space-between;
      align-items: center;
      text-align: left;
      gap: 1.5rem;
    }

    .footer-mega-card__copyright {
      flex: 0 1 auto;
      text-align: left;
    }

    .footer-mega-card__legal {
      flex: 1 1 auto;
      justify-content: center;
    }

    .footer-mega-card__social {
      flex: 0 0 auto;
      justify-content: flex-end;
    }
  }

  .footer-mega-card__copyright {
    margin: 0;
    opacity: 0.85;
  }

  .footer-mega-card__legal {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem 1.25rem;
    justify-content: center;
  }

  .footer-mega-card__legal a {
    color: inherit;
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .footer-mega-card__social {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    justify-content: center;
  }

  .footer-mega-card__social-link {
    display: flex;
    color: #111;
    opacity: 0.9;
  }

  .footer-mega-card__social-link:hover {
    opacity: 1;
  }

  .footer-mega-card__social-icon {
    width: 1.25rem;
    height: 1.25rem;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Mega card footer",
  "class": "section-wrapper",
  "tag": "section",
  "enabled_on": {
    "groups": ["footer"]
  },
  "max_blocks": 8,
  "settings": [
    {
      "type": "select",
      "id": "section_width",
      "label": "Width",
      "options": [
        { "value": "page-width", "label": "Page width" },
        { "value": "full-width", "label": "Full width" }
      ],
      "default": "page-width"
    },
    {
      "type": "header",
      "content": "Surround"
    },
    {
      "type": "color",
      "id": "page_background",
      "label": "Background behind card",
      "default": "#0d9488"
    },
    {
      "type": "color",
      "id": "gradient_color_end",
      "label": "Background gradient end",
      "info": "Optional second color for a diagonal gradient behind the card."
    },
    {
      "type": "color",
      "id": "card_background",
      "label": "Card background",
      "default": "#f7f3ea"
    },
    {
      "type": "range",
      "id": "card_border_radius",
      "label": "Card corner radius",
      "min": 0,
      "max": 48,
      "step": 2,
      "unit": "px",
      "default": 24
    },
    {
      "type": "range",
      "id": "card_padding",
      "label": "Card padding",
      "min": 16,
      "max": 72,
      "step": 4,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "column_gap",
      "label": "Column gap",
      "min": 8,
      "max": 48,
      "step": 4,
      "unit": "px",
      "default": 24
    },
    {
      "type": "color",
      "id": "divider_color",
      "label": "Divider line",
      "default": "#1a1a1a"
    },
    {
      "type": "header",
      "content": "Logo"
    },
    {
      "type": "image_picker",
      "id": "logo_image",
      "label": "Logo image"
    },
    {
      "type": "text",
      "id": "logo_text",
      "label": "Logo text (if no image)"
    },
    {
      "type": "url",
      "id": "logo_link",
      "label": "Logo link"
    },
    {
      "type": "header",
      "content": "Copyright"
    },
    {
      "type": "richtext",
      "id": "copyright_custom",
      "label": "Custom copyright",
      "info": "Leave empty to use year and store name."
    },
    {
      "type": "header",
      "content": "Legal links"
    },
    {
      "type": "text",
      "id": "privacy_label",
      "label": "Privacy label",
      "default": "Privacy Policy"
    },
    {
      "type": "url",
      "id": "privacy_url",
      "label": "Privacy URL"
    },
    {
      "type": "text",
      "id": "terms_label",
      "label": "Terms label",
      "default": "Terms of Service"
    },
    {
      "type": "url",
      "id": "terms_url",
      "label": "Terms URL"
    },
    {
      "type": "text",
      "id": "cookies_label",
      "label": "Cookies label",
      "default": "Cookies Settings"
    },
    {
      "type": "url",
      "id": "cookies_url",
      "label": "Cookies URL"
    },
    {
      "type": "header",
      "content": "Social"
    },
    {
      "type": "url",
      "id": "facebook_url",
      "label": "Facebook"
    },
    {
      "type": "url",
      "id": "instagram_url",
      "label": "Instagram"
    },
    {
      "type": "url",
      "id": "twitter_url",
      "label": "X (Twitter)"
    },
    {
      "type": "url",
      "id": "linkedin_url",
      "label": "LinkedIn"
    },
    {
      "type": "url",
      "id": "youtube_url",
      "label": "YouTube"
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "Top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "Bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding-inline-start",
      "label": "Left",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding-inline-end",
      "label": "Right",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 0
    }
  ],
  "blocks": [
    {
      "type": "column",
      "name": "Menu column",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Column"
        },
        {
          "type": "link_list",
          "id": "menu",
          "label": "Menu"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Mega card footer",
      "blocks": [
        { "type": "column", "settings": { "heading": "Column one" } },
        { "type": "column", "settings": { "heading": "Column two" } },
        { "type": "column", "settings": { "heading": "Column three" } },
        { "type": "column", "settings": { "heading": "Column four" } },
        { "type": "column", "settings": { "heading": "Column five" } }
      ]
    }
  ]
}
{% endschema %}
