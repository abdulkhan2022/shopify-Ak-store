<div class="medium-length-hero">
  <div class="medium-length-hero__inner page-width-content">
    <div class="medium-length-hero__top">
      <div class="medium-length-hero__titles">
        {% if section.settings.heading_line_1 != blank %}
          <p class="medium-length-hero__line1">{{ section.settings.heading_line_1 | escape }}</p>
        {% endif %}
        <p class="medium-length-hero__line2">
          {% if section.settings.subheading_italic != blank %}
            <span class="medium-length-hero__line2-italic">{{ section.settings.subheading_italic | escape }}</span>
          {% endif %}
          {% if section.settings.subheading_suffix != blank %}
            <span class="medium-length-hero__line2-sans"> {{ section.settings.subheading_suffix | escape }}</span>
          {% endif %}
        </p>
      </div>
      {% if section.settings.description != blank %}
        <div class="medium-length-hero__intro rte">{{ section.settings.description }}</div>
      {% endif %}
    </div>

    <div class="medium-length-hero__media">
      <div class="medium-length-hero__media-frame">
        {% if section.settings.video_thumbnail != blank %}
          {% liquid
            assign mlh_alt = section.settings.video_thumbnail.alt | default: section.settings.heading_line_1
          %}
          {{
            section.settings.video_thumbnail
            | image_url: width: 2400
            | image_tag:
              class: 'medium-length-hero__image',
              loading: 'lazy',
              sizes: '(min-width: 990px) min(90vw, 1200px), 100vw',
              alt: mlh_alt
          }}
        {% else %}
          <div class="medium-length-hero__placeholder" aria-hidden="true"></div>
        {% endif %}

        {% if section.settings.video_url != blank %}
          <a
            class="medium-length-hero__play"
            href="{{ section.settings.video_url }}"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="{{ 'accessibility.play_video' | t }}"
          >
            <span class="medium-length-hero__play-circle">
              <svg class="medium-length-hero__play-icon" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
                <polygon points="9,7 9,17 17,12" fill="currentColor"/>
              </svg>
            </span>
          </a>
        {% else %}
          <span class="medium-length-hero__play" role="presentation">
            <span class="medium-length-hero__play-circle">
              <svg class="medium-length-hero__play-icon" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
                <polygon points="9,7 9,17 17,12" fill="currentColor"/>
              </svg>
            </span>
          </span>
        {% endif %}
      </div>
    </div>
  </div>
</div>

{% stylesheet %}
  .medium-length-hero {
    --mlh-cream: #fcf8f0;
    --mlh-frame: #ebe8e4;
    background-color: var(--mlh-cream);
    padding-block: clamp(3rem, 7vw, 5rem);
    padding-inline: var(--page-margin, 1.5rem);
  }

  .medium-length-hero__inner {
    max-width: 1440px;
    margin-inline: auto;
  }

  .medium-length-hero__top {
    display: grid;
    gap: clamp(1.5rem, 4vw, 2.5rem);
    align-items: start;
  }

  @media screen and (min-width: 990px) {
    .medium-length-hero__top {
      grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
      gap: clamp(2rem, 5vw, 4rem);
    }
  }

  .medium-length-hero__titles {
    text-align: left;
  }

  .medium-length-hero__line1 {
    margin: 0;
    font-family: var(--font-heading--family);
    font-style: var(--font-heading--style, normal);
    font-weight: 700;
    font-size: clamp(2rem, 4.2vw, 3rem);
    line-height: 1.05;
    letter-spacing: -0.02em;
    color: rgb(var(--color-foreground-rgb, 0 0 0));
  }

  .medium-length-hero__line2 {
    margin: 0.35em 0 0;
    font-size: clamp(1.5rem, 2.8vw, 2.25rem);
    line-height: 1.15;
    color: rgb(var(--color-foreground-rgb, 0 0 0));
  }

  .medium-length-hero__line2-italic {
    font-family: var(--font-subheading--family);
    font-style: italic;
    font-weight: 400;
  }

  .medium-length-hero__line2-sans {
    font-family: var(--font-body--family);
    font-style: normal;
    font-weight: 400;
  }

  .medium-length-hero__intro {
    margin: 0;
    font-family: var(--font-body--family);
    font-size: clamp(0.9375rem, 1.1vw, 1rem);
    line-height: 1.65;
    color: rgb(var(--color-foreground-rgb, 0 0 0));
  }

  @media screen and (min-width: 990px) {
    .medium-length-hero__intro {
      padding-top: 0.25rem;
      max-width: 42ch;
      justify-self: end;
      text-align: left;
    }
  }

  .medium-length-hero__media {
    margin-top: clamp(2rem, 5vw, 3.5rem);
  }

  .medium-length-hero__media-frame {
    position: relative;
    border-radius: 12px;
    overflow: hidden;
    background-color: var(--mlh-frame);
    aspect-ratio: 16 / 9;
    box-shadow: 0 12px 40px rgb(var(--color-foreground-rgb, 0 0 0) / 0.08);
  }

  .medium-length-hero__image,
  .medium-length-hero__placeholder {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .medium-length-hero__placeholder {
    background: linear-gradient(135deg, #e8e4df 0%, #f0ebe5 100%);
  }

  .medium-length-hero__play {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    text-decoration: none;
    border: none;
    background: transparent;
    cursor: pointer;
  }

  .medium-length-hero__play-circle {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 4rem;
    height: 4rem;
    border-radius: 50%;
    background-color: #fff;
    color: #111;
    box-shadow: 0 4px 24px rgb(0 0 0 / 0.12);
    transition: transform 0.2s ease;
  }

  a.medium-length-hero__play:hover .medium-length-hero__play-circle,
  a.medium-length-hero__play:focus-visible .medium-length-hero__play-circle {
    transform: scale(1.06);
  }

  .medium-length-hero__play-icon {
    width: 1.25rem;
    height: 1.25rem;
    margin-left: 0.15rem;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Medium Length Hero",
  "tag": "section",
  "class": "section-wrapper",
  "settings": [
    {
      "type": "text",
      "id": "heading_line_1",
      "label": "Heading line 1",
      "default": "Medium length hero"
    },
    {
      "type": "text",
      "id": "subheading_italic",
      "label": "Heading line 2 (italic part)",
      "default": "heading goes"
    },
    {
      "type": "text",
      "id": "subheading_suffix",
      "label": "Heading line 2 (regular part)",
      "default": "here"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Intro text (right column)",
      "default": "<p>Lorem ipsum dolor sit amet, consectetur adipiscing elit. Suspendisse varius enim in eros elementum tristique. Duis cursus, mi quis viverra ornare, eros dolor interdum nulla, ut commodo diam libero vitae erat.</p>"
    },
    {
      "type": "image_picker",
      "id": "video_thumbnail",
      "label": "Image / video poster"
    },
    {
      "type": "video_url",
      "id": "video_url",
      "label": "Video URL",
      "accept": ["youtube", "vimeo"],
      "info": "Optional. The play button opens this link in a new tab."
    }
  ],
  "presets": [
    {
      "name": "Medium Length Hero"
    }
  ]
}
{% endschema %}
