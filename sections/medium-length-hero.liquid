<div class="medium-length-hero">
  <div class="medium-length-hero__content">
    <div class="medium-length-hero__text-wrapper">
      <h2 class="medium-length-hero__heading">Medium length hero</h2>
      <p class="medium-length-hero__subheading">heading goes here</p>
    </div>
    <div class="medium-length-hero__description">
      <p>Lorem ipsum dolor sit amet, consectetur adipiscing elit. Suspendisse varius enim in eros elementum tristique. Duis cursus, mi quis viverra ornare, eros dolor interdum nulla, ut commodo diam libero vitae erat.</p>
    </div>
  </div>
  <div class="medium-length-hero__video-wrapper">
    <div class="medium-length-hero__video-container">
      <img src="https://cdn.shopify.com/s/files/1/0533/2083/files/placeholder_image.png?v=1613523581" alt="Placeholder video thumbnail" class="medium-length-hero__video-thumbnail">
      <button class="medium-length-hero__play-button">
        <svg aria-hidden="true" focusable="false" role="presentation" class="icon icon-play" viewBox="0 0 13 13">
          <path fill="currentColor" d="M0 0h13v13H0V0z"/>
          <path d="M4.322 2.668c-1.397-.582-2.322.28-2.322 1.332v5.66c0 1.052.925 1.914 2.322 1.332L10.32 6.54C11.717 5.958 11.717 4.042 10.32 3.46L4.322 2.668z" fill="#fff"/>
        </svg>
      </button>
    </div>
  </div>
</div>

{% stylesheet %}
.medium-length-hero {
  background-color: #fcf8f0; /* Light cream background */
  padding: 80px 40px;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 40px;
}

@media (min-width: 768px) {
  .medium-length-hero {
    flex-direction: row;
    justify-content: center;
    align-items: flex-start;
    gap: 80px;
    padding: 100px 80px;
  }
}

.medium-length-hero__content {
  display: flex;
  flex-direction: column;
  gap: 20px;
  max-width: 500px;
}

@media (min-width: 768px) {
  .medium-length-hero__content {
    flex-basis: 50%;
  }
}

.medium-length-hero__text-wrapper {
  margin-bottom: 20px;
}

.medium-length-hero__heading {
  font-size: 2.5rem;
  font-weight: bold;
  margin-bottom: 10px;
  line-height: 1.1;
}

.medium-length-hero__subheading {
  font-size: 1.8rem;
  font-style: italic;
  color: #555;
  line-height: 1.1;
}

.medium-length-hero__description p {
  font-size: 1rem;
  line-height: 1.6;
  color: #333;
}

@media (min-width: 768px) {
  .medium-length-hero__description {
    text-align: left;
  }
}

.medium-length-hero__video-wrapper {
  flex-basis: 50%;
  max-width: 600px;
  position: relative;
}

.medium-length-hero__video-container {
  position: relative;
  width: 100%;
  padding-top: 56.25%; /* 16:9 Aspect Ratio */
  background-color: #eee;
  border-radius: 8px;
  overflow: hidden;
  box-shadow: 0 10px 30px rgba(0, 0, 0, 0.1);
}

.medium-length-hero__video-thumbnail {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.medium-length-hero__play-button {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  background-color: rgba(255, 255, 255, 0.8);
  border: none;
  border-radius: 50%;
  width: 60px;
  height: 60px;
  display: flex;
  justify-content: center;
  align-items: center;
  cursor: pointer;
  z-index: 10;
  transition: transform 0.2s ease-in-out;
}

.medium-length-hero__play-button:hover {
  transform: translate(-50%, -50%) scale(1.1);
}

.medium-length-hero__play-button svg {
  width: 24px;
  height: 24px;
  fill: #000;
}
{% endstylesheet %}

{% schema %}
{
  "name": "Medium Length Hero",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Medium length hero"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "heading goes here"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Description",
      "default": "<p>Lorem ipsum dolor sit amet, consectetur adipiscing elit. Suspendisse varius enim in eros elementum tristique. Duis cursus, mi quis viverra ornare, eros dolor interdum nulla, ut commodo diam libero vitae erat.</p>"
    },
    {
      "type": "image_picker",
      "id": "video_thumbnail",
      "label": "Video Thumbnail",
      "info": "Upload an image for the video thumbnail."
    },
    {
      "type": "video_url",
      "id": "video_url",
      "label": "Video URL",
      "accept": ["youtube", "vimeo"],
      "info": "Provide a YouTube or Vimeo video URL."
    }
  ],
  "presets": [
    {
      "name": "Medium Length Hero"
    }
  ]
}
{% endschema %}