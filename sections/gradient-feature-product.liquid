{%- liquid
  assign section_id = 'gradient-feature-product-' | append: section.id
  assign selected_product = section.settings.product
-%}

<section
  id="{{ section_id }}"
  class="gradient-feature-product section section--full-width color-{{ section.settings.color_scheme }}"
  style="{% render 'spacing-padding', settings: section.settings %}"
>
  <div class="gradient-feature-product__inner">
    {%- if section.settings.label != blank -%}
      <p class="gradient-feature-product__pill">{{ section.settings.label | escape }}</p>
    {%- endif -%}

    {%- if section.settings.heading != blank -%}
      <div class="gradient-feature-product__heading rte">{{ section.settings.heading }}</div>
    {%- endif -%}

    <div class="gradient-feature-product__content">
      <div class="gradient-feature-product__image-wrap">
        {%- if section.settings.left_image != blank -%}
          {{
            section.settings.left_image
            | image_url: width: 1400
            | image_tag:
              class: 'gradient-feature-product__image',
              loading: 'lazy',
              sizes: '(min-width: 990px) 54vw, 100vw'
          }}
        {%- else -%}
          {{ 'hero-apparel-1' | placeholder_svg_tag: 'gradient-feature-product__image gradient-feature-product__image--placeholder' }}
        {%- endif -%}
      </div>

      <div class="gradient-feature-product__card-wrap">
        <button type="button" class="gradient-feature-product__nav" aria-label="Previous slide">&larr;</button>

        <article class="gradient-feature-product__card">
          <div class="gradient-feature-product__card-media">
            {%- if selected_product != blank and selected_product.featured_image != blank -%}
              {{
                selected_product.featured_image
                | image_url: width: 700
                | image_tag:
                  class: 'gradient-feature-product__product-image',
                  loading: 'lazy',
                  sizes: '(min-width: 990px) 20vw, 70vw'
              }}
            {%- elsif section.settings.product_image != blank -%}
              {{
                section.settings.product_image
                | image_url: width: 700
                | image_tag:
                  class: 'gradient-feature-product__product-image',
                  loading: 'lazy',
                  sizes: '(min-width: 990px) 20vw, 70vw'
              }}
            {%- else -%}
              {{ 'product-1' | placeholder_svg_tag: 'gradient-feature-product__product-image gradient-feature-product__product-image--placeholder' }}
            {%- endif -%}
          </div>

          <div class="gradient-feature-product__card-row">
            <h3 class="gradient-feature-product__product-title">
              {%- if selected_product != blank -%}
                {{ selected_product.title | escape }}
              {%- else -%}
                {{ section.settings.product_title | escape }}
              {%- endif -%}
            </h3>
            <p class="gradient-feature-product__price">
              {%- if selected_product != blank -%}
                {{ selected_product.price | money }}
              {%- else -%}
                {{ section.settings.product_price | escape }}
              {%- endif -%}
            </p>
          </div>

          <p class="gradient-feature-product__rating">★ {{ section.settings.rating_text | escape }}</p>

          <a
            class="gradient-feature-product__button"
            href="{% if selected_product != blank %}{{ selected_product.url }}{% elsif section.settings.button_link != blank %}{{ section.settings.button_link }}{% else %}#{% endif %}"
          >
            {{ section.settings.button_label | escape }}
          </a>
        </article>

        <button type="button" class="gradient-feature-product__nav" aria-label="Next slide">&rarr;</button>
      </div>
    </div>
  </div>

  <style>
    #{{ section_id }}.gradient-feature-product {
      margin-top: -10px;
      border-radius: 24px 24px 0 0;
      overflow: hidden;
      background:
        radial-gradient(70% 60% at 30% 2%, rgb(255 255 255 / 35%), transparent 70%),
        radial-gradient(60% 70% at 95% 58%, rgb(255 133 199 / 55%), transparent 70%),
        linear-gradient(135deg, #4b4da1 0%, #486cb0 45%, #b883c8 100%);
      color: #f7f7f7;
    }

    #{{ section_id }} .gradient-feature-product__inner {
      width: min(1320px, calc(100% - (var(--page-margin, 24px) * 2)));
      margin: 0 auto;
      text-align: center;
    }

    #{{ section_id }} .gradient-feature-product__pill {
      display: inline-flex;
      margin: 0 0 14px;
      padding: 6px 16px;
      border: 1px solid rgb(255 255 255 / 60%);
      border-radius: 999px;
      font-size: 0.9rem;
      line-height: 1;
      color: #fff;
    }

    #{{ section_id }} .gradient-feature-product__heading {
      margin: 0 auto 34px;
      max-width: 860px;
      font-size: clamp(2rem, 4.2vw, 4rem);
      line-height: 1.05;
      letter-spacing: -0.02em;
      color: #fff;
    }

    #{{ section_id }} .gradient-feature-product__heading p {
      margin: 0;
    }

    #{{ section_id }} .gradient-feature-product__content {
      display: grid;
      grid-template-columns: minmax(0, 1.05fr) minmax(0, 0.95fr);
      gap: clamp(20px, 4vw, 44px);
      align-items: end;
    }

    #{{ section_id }} .gradient-feature-product__image-wrap {
      border: 1px solid rgb(255 255 255 / 65%);
      border-radius: 20px;
      overflow: hidden;
      min-height: 420px;
      background: rgb(255 255 255 / 12%);
    }

    #{{ section_id }} .gradient-feature-product__image {
      display: block;
      width: 100%;
      height: 100%;
      object-fit: cover;
    }

    #{{ section_id }} .gradient-feature-product__card-wrap {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 18px;
      padding-bottom: 34px;
    }

    #{{ section_id }} .gradient-feature-product__nav {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 40px;
      height: 40px;
      border: 0;
      border-radius: 999px;
      background: #f6f3e7;
      color: #1b1b1b;
      font-size: 1.2rem;
      cursor: default;
    }

    #{{ section_id }} .gradient-feature-product__card {
      width: min(250px, 100%);
      background: #f3f0e6;
      color: #161616;
      border-radius: 16px;
      padding: 10px;
      text-align: left;
      box-shadow: 0 10px 28px rgb(0 0 0 / 18%);
    }

    #{{ section_id }} .gradient-feature-product__card-media {
      border-radius: 10px;
      overflow: hidden;
      background: #ddd8cb;
    }

    #{{ section_id }} .gradient-feature-product__product-image {
      display: block;
      width: 100%;
      height: auto;
      object-fit: cover;
      aspect-ratio: 1 / 1;
    }

    #{{ section_id }} .gradient-feature-product__card-row {
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
      gap: 10px;
      margin-top: 10px;
    }

    #{{ section_id }} .gradient-feature-product__product-title {
      margin: 0;
      font-size: 1.75rem;
      line-height: 1.08;
      letter-spacing: -0.01em;
      font-weight: 400;
      text-wrap: balance;
    }

    #{{ section_id }} .gradient-feature-product__price {
      margin: 0;
      font-size: 1.6rem;
      line-height: 1;
      white-space: nowrap;
    }

    #{{ section_id }} .gradient-feature-product__rating {
      margin: 8px 0 10px;
      font-size: 0.95rem;
      line-height: 1;
    }

    #{{ section_id }} .gradient-feature-product__button {
      display: flex;
      align-items: center;
      justify-content: center;
      min-height: 38px;
      border-radius: 999px;
      border: 1px solid rgb(0 0 0 / 40%);
      color: #191919;
      text-decoration: none;
      font-size: 0.95rem;
      background: transparent;
    }

    @media (max-width: 989px) {
      #{{ section_id }} .gradient-feature-product__content {
        grid-template-columns: 1fr;
      }

      #{{ section_id }} .gradient-feature-product__image-wrap {
        min-height: 340px;
      }

      #{{ section_id }} .gradient-feature-product__card-wrap {
        padding-bottom: 0;
      }
    }
  </style>
</section>

{% schema %}
{
  "name": "Gradient feature product",
  "settings": [
    { "type": "color_scheme", "id": "color_scheme", "label": "t:settings.color_scheme", "default": "scheme-6" },
    { "type": "text", "id": "label", "label": "Top label", "default": "Shop by category" },
    { "type": "richtext", "id": "heading", "label": "Heading", "default": "<p>Lorem Ipsum is simply dummy text of the printing and <em>typesetting industry</em>.</p>" },
    { "type": "image_picker", "id": "left_image", "label": "Left image" },
    { "type": "product", "id": "product", "label": "Product" },
    { "type": "image_picker", "id": "product_image", "label": "Fallback product image" },
    { "type": "text", "id": "product_title", "label": "Fallback product title", "default": "Cordycep Mushroom Tincture" },
    { "type": "text", "id": "product_price", "label": "Fallback price", "default": "$55" },
    { "type": "text", "id": "rating_text", "label": "Rating text", "default": "4.5/5" },
    { "type": "text", "id": "button_label", "label": "Button label", "default": "Add to cart" },
    { "type": "url", "id": "button_link", "label": "Fallback button link" },
    { "type": "range", "id": "padding-block-start", "min": 0, "max": 160, "step": 2, "unit": "px", "label": "t:settings.top_padding", "default": 90 },
    { "type": "range", "id": "padding-block-end", "min": 0, "max": 160, "step": 2, "unit": "px", "label": "t:settings.bottom_padding", "default": 90 }
  ],
  "presets": [
    {
      "name": "Gradient feature product"
    }
  ]
}
{% endschema %}
