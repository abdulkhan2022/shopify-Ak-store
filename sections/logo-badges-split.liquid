<div class="logo-badges-split">
  <div class="logo-badges-split__inner">
    <div class="logo-badges-split__content">
      <div class="logo-badges-split__text">
        {% if section.settings.heading != blank %}
          <h2 class="logo-badges-split__heading">{{ section.settings.heading | escape }}</h2>
        {% endif %}
        {% if section.settings.subtext != blank %}
          <div class="logo-badges-split__subtext rte">{{ section.settings.subtext }}</div>
        {% endif %}
      </div>

      {% if section.blocks.size > 0 %}
        <div class="logo-badges-split__grid" role="list">
          {% for block in section.blocks %}
            <div class="logo-badges-split__badge" role="listitem" {{ block.shopify_attributes }}>
              {% if block.settings.icon != blank %}
                <span class="logo-badges-split__icon-wrap">
                  {% liquid
                    assign icon_alt = block.settings.label | default: 'Logo'
                  %}
                  {{
                    block.settings.icon
                    | image_url: width: 128
                    | image_tag:
                      class: 'logo-badges-split__icon',
                      loading: 'lazy',
                      sizes: '32px',
                      widths: '64, 128',
                      alt: icon_alt
                  }}
                </span>
              {% else %}
                <span class="logo-badges-split__icon-wrap logo-badges-split__icon-wrap--empty" aria-hidden="true"></span>
              {% endif %}
              {% if block.settings.label != blank %}
                <span class="logo-badges-split__label">{{ block.settings.label | escape }}</span>
              {% endif %}
            </div>
          {% endfor %}
        </div>
      {% endif %}
    </div>
  </div>
</div>

{% stylesheet %}
  .logo-badges-split {
    --lbs-bg: #fdfcf0;
    background-color: var(--lbs-bg);
    padding-block: clamp(3rem, 8vw, 5.5rem);
    padding-inline: var(--page-margin, 1.5rem);
  }

  .logo-badges-split__inner {
    max-width: 1440px;
    margin-inline: auto;
  }

  .logo-badges-split__content {
    max-width: 1440px;
    margin-inline: auto;
    display: grid;
    gap: clamp(2rem, 5vw, 3rem);
    align-items: start;
  }

  @media screen and (min-width: 900px) {
    .logo-badges-split__content {
      grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
      gap: clamp(2rem, 4vw, 3.5rem);
    }
  }

  .logo-badges-split__text {
    text-align: left;
  }

  .logo-badges-split__heading {
    margin: 0 0 clamp(1rem, 2.5vw, 1.35rem);
    font-family: var(--font-heading--family);
    font-style: var(--font-heading--style, normal);
    font-weight: 700;
    font-size: clamp(1.5rem, 3.2vw, 2.25rem);
    line-height: 1.2;
    letter-spacing: -0.02em;
    color: rgb(var(--color-foreground-rgb, 0 0 0));
  }

  .logo-badges-split__subtext {
    margin: 0;
    font-family: var(--font-body--family);
    font-size: clamp(0.9375rem, 1.05vw, 1.0625rem);
    font-weight: 400;
    line-height: 1.6;
    color: rgb(var(--color-foreground-rgb, 0 0 0));
  }

  .logo-badges-split__subtext p {
    margin: 0;
  }

  .logo-badges-split__grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.75rem 0.875rem;
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .logo-badges-split__badge {
    display: flex;
    align-items: center;
    gap: 0.65rem;
    padding: 0.75rem 0.85rem;
    background-color: #fff;
    border-radius: 10px;
    box-shadow: 0 1px 3px rgb(var(--color-foreground-rgb, 0 0 0) / 0.06);
    min-height: 3rem;
  }

  .logo-badges-split__icon-wrap {
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
  }

  .logo-badges-split__icon-wrap--empty {
    border-radius: 6px;
    background: rgb(var(--color-foreground-rgb, 0 0 0) / 0.06);
  }

  .logo-badges-split__icon {
    display: block;
    width: 28px;
    height: 28px;
    object-fit: contain;
  }

  .logo-badges-split__label {
    font-family: var(--font-body--family);
    font-size: 0.875rem;
    font-weight: 500;
    line-height: 1.3;
    color: rgb(var(--color-foreground-rgb, 0 0 0));
    text-align: left;
  }
{% endstylesheet %}

