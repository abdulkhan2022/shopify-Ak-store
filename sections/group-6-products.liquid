{%- liquid
  assign section_id = 'group-6-products-' | append: section.id
  assign products_limit = section.settings.products_to_show | default: 8
  assign collection_products = section.settings.collection.products
  assign has_products = false
  if section.settings.collection != blank and collection_products.size > 0
    assign has_products = true
  endif
-%}

<section
  id="{{ section_id }}"
  class="group-6-products section section--full-width color-{{ section.settings.color_scheme }}"
  style="{% render 'spacing-padding', settings: section.settings %}"
>
  <div class="group-6-products__surface">
    <div class="group-6-products__inner">
      <div class="group-6-products__head">
        <div class="group-6-products__head-copy">
          {%- if section.settings.pill_label != blank -%}
            <p class="group-6-products__pill">{{ section.settings.pill_label | escape }}</p>
          {%- endif -%}
          {%- if section.settings.heading != blank -%}
            <h2 class="group-6-products__heading">{{ section.settings.heading | escape }}</h2>
          {%- endif -%}
          {%- if section.settings.description != blank -%}
            <p class="group-6-products__description">{{ section.settings.description | escape }}</p>
          {%- endif -%}
        </div>
        {%- if section.settings.button_label != blank -%}
          <a class="group-6-products__cta button button-secondary" href="{{ section.settings.button_link | default: '#' }}">
            {{ section.settings.button_label | escape }}
          </a>
        {%- endif -%}
      </div>

      <group-6-products-carousel class="group-6-products__carousel-wrap">
        <div class="group-6-products__carousel" data-carousel-track>
          {%- if has_products -%}
            {%- for product in collection_products limit: products_limit -%}
              {%- assign featured = product.featured_media -%}
              {%- assign first_variant = product.selected_or_first_available_variant -%}
              <article class="group-6-products__card">
                <a href="{{ product.url }}" class="group-6-products__media-link">
                  <div class="group-6-products__media-shell">
                    {%- if featured != blank -%}
                      {{
                        featured
                        | image_url: width: 620
                        | image_tag: class: 'group-6-products__media', loading: 'lazy', sizes: '(min-width: 990px) 25vw, 70vw', alt: featured.alt
                      }}
                    {%- else -%}
                      {{ 'product-1' | placeholder_svg_tag: 'group-6-products__media group-6-products__media--placeholder' }}
                    {%- endif -%}
                  </div>
                </a>
                <div class="group-6-products__card-body">
                  <div class="group-6-products__title-row">
                    <a href="{{ product.url }}" class="group-6-products__title">{{ product.title | escape }}</a>
                    <span class="group-6-products__price">{{ product.price | money }}</span>
                  </div>
                  <p class="group-6-products__rating">★ 4.5/5</p>
                  <form method="post" action="/cart/add" class="group-6-products__form">
                    <input type="hidden" name="id" value="{{ first_variant.id }}">
                    <button type="submit" class="group-6-products__atc" {% unless first_variant.available %}disabled{% endunless %}>
                      {% if first_variant.available %}Add to cart{% else %}Sold out{% endif %}
                    </button>
                  </form>
                </div>
              </article>
            {%- endfor -%}
          {%- else -%}
            {%- for i in (1..4) -%}
              <article class="group-6-products__card">
                <div class="group-6-products__media-shell">
                  {{ 'product-' | append: i | placeholder_svg_tag: 'group-6-products__media group-6-products__media--placeholder' }}
                </div>
                <div class="group-6-products__card-body">
                  <div class="group-6-products__title-row">
                    <p class="group-6-products__title">Cordycep Mushroom Tincture</p>
                    <span class="group-6-products__price">$55</span>
                  </div>
                  <p class="group-6-products__rating">★ 4.5/5</p>
                  <button type="button" class="group-6-products__atc">Add to cart</button>
                </div>
              </article>
            {%- endfor -%}
          {%- endif -%}
        </div>

        <div class="group-6-products__controls">
          <div class="group-6-products__dots" data-carousel-dots></div>
          <div class="group-6-products__arrows">
            <button type="button" class="group-6-products__arrow" data-carousel-prev aria-label="Previous">
              <span>&larr;</span>
            </button>
            <button type="button" class="group-6-products__arrow" data-carousel-next aria-label="Next">
              <span>&rarr;</span>
            </button>
          </div>
        </div>
      </group-6-products-carousel>
    </div>
  </div>

  <style>
    #{{ section_id }}.group-6-products{background:#fff}
    #{{ section_id }} .group-6-products__surface{width:100%;border-radius:18px 18px 0 0;background:linear-gradient(132deg,#1dc4c3 0%,#2d93cf 52%,#2f84cb 100%);padding:clamp(30px,4vw,48px) var(--page-margin) clamp(28px,4vw,44px)}
    #{{ section_id }} .group-6-products__inner{max-width:1440px;margin:0 auto}
    #{{ section_id }} .group-6-products__head{display:flex;justify-content:space-between;gap:24px;align-items:flex-start;margin-bottom:24px}
    #{{ section_id }} .group-6-products__pill{margin:0 0 10px;display:inline-flex;padding:6px 12px;border:1px solid rgb(255 255 255 / 60%);border-radius:999px;color:#eafbf7;font-size:.8rem;line-height:1}
    #{{ section_id }} .group-6-products__heading{margin:0;color:#fff;font-size:clamp(2rem,3.5vw,3rem);line-height:1.05;font-weight:400}
    #{{ section_id }} .group-6-products__description{margin:10px 0 0;color:rgb(236 255 252 / 90%);font-size:1.05rem;line-height:1.35;max-width:40ch}
    #{{ section_id }} .group-6-products__cta{border-radius:999px;background:#f5f4e7 !important;color:#1f2730 !important;border-color:#f5f4e7 !important;white-space:nowrap;margin-top:58px}
    #{{ section_id }} .group-6-products__carousel-wrap{display:block}
    #{{ section_id }} .group-6-products__carousel{display:grid;grid-auto-flow:column;grid-auto-columns:calc((100% - 3 * 16px)/4);gap:16px;overflow-x:auto;scroll-snap-type:x mandatory;scrollbar-width:none;padding-bottom:6px}
    #{{ section_id }} .group-6-products__carousel::-webkit-scrollbar{display:none}
    #{{ section_id }} .group-6-products__card{scroll-snap-align:start;background:#f4f2e8;border-radius:12px;padding:8px}
    #{{ section_id }} .group-6-products__media-shell{background:#d8d6d0;border-radius:9px;overflow:hidden;aspect-ratio:0.86}
    #{{ section_id }} .group-6-products__media{width:100%;height:100%;object-fit:cover;display:block}
    #{{ section_id }} .group-6-products__card-body{padding:8px 2px 0}
    #{{ section_id }} .group-6-products__title-row{display:flex;justify-content:space-between;gap:8px;align-items:flex-start}
    #{{ section_id }} .group-6-products__title{margin:0;color:#111;font-size:1.65rem;line-height:1.05;text-decoration:none;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden}
    #{{ section_id }} .group-6-products__price{font-size:1.4rem;line-height:1;color:#111;white-space:nowrap}
    #{{ section_id }} .group-6-products__rating{margin:6px 0 8px;color:#111;font-size:1rem}
    #{{ section_id }} .group-6-products__atc{width:100%;height:42px;border:1px solid rgb(17 17 17 / 55%);background:transparent;border-radius:999px;font-size:1.25rem;color:#111}
    #{{ section_id }} .group-6-products__controls{margin-top:18px;display:flex;justify-content:space-between;align-items:center}
    #{{ section_id }} .group-6-products__dots{display:flex;gap:6px}
    #{{ section_id }} .group-6-products__dot{width:6px;height:6px;border-radius:50%;background:rgb(255 255 255 / 36%);border:none;padding:0}
    #{{ section_id }} .group-6-products__dot.is-active{background:#f6f4e8}
    #{{ section_id }} .group-6-products__arrows{display:flex;gap:8px}
    #{{ section_id }} .group-6-products__arrow{width:36px;height:36px;border:none;border-radius:50%;background:#f5f4e7;color:#252525}
    @media (max-width:989px){#{{ section_id }} .group-6-products__head{flex-direction:column}#{{ section_id }} .group-6-products__cta{margin-top:4px}#{{ section_id }} .group-6-products__carousel{grid-auto-columns:calc((100% - 16px)/2)}}
    @media (max-width:749px){#{{ section_id }} .group-6-products__surface{border-radius:14px 14px 0 0}#{{ section_id }} .group-6-products__carousel{grid-auto-columns:84%}#{{ section_id }} .group-6-products__controls{margin-top:14px}}
  </style>

  <script>
    (() => {
      class Group6ProductsCarousel extends HTMLElement {
        connectedCallback() {
          this.track = this.querySelector('[data-carousel-track]');
          this.prev = this.querySelector('[data-carousel-prev]');
          this.next = this.querySelector('[data-carousel-next]');
          this.dots = this.querySelector('[data-carousel-dots]');
          if (!this.track) return;
          this.onScroll = this.onScroll.bind(this);
          this.onResize = this.onResize.bind(this);
          this.prev?.addEventListener('click', () => this.move(-1));
          this.next?.addEventListener('click', () => this.move(1));
          this.track.addEventListener('scroll', this.onScroll, { passive: true });
          window.addEventListener('resize', this.onResize);
          this.buildDots();
          this.onScroll();
        }
        disconnectedCallback() {
          this.track?.removeEventListener('scroll', this.onScroll);
          window.removeEventListener('resize', this.onResize);
        }
        pageWidth() {
          return this.track.clientWidth;
        }
        pageCount() {
          return Math.max(1, Math.round(this.track.scrollWidth / this.pageWidth()));
        }
        activePage() {
          return Math.round(this.track.scrollLeft / this.pageWidth());
        }
        move(direction) {
          this.track.scrollBy({ left: direction * this.pageWidth(), behavior: 'smooth' });
        }
        buildDots() {
          if (!this.dots) return;
          this.dots.innerHTML = '';
          const count = this.pageCount();
          for (let i = 0; i < count; i++) {
            const dot = document.createElement('button');
            dot.type = 'button';
            dot.className = 'group-6-products__dot';
            dot.setAttribute('aria-label', `Go to slide ${i + 1}`);
            dot.addEventListener('click', () => {
              this.track.scrollTo({ left: i * this.pageWidth(), behavior: 'smooth' });
            });
            this.dots.appendChild(dot);
          }
        }
        onResize() {
          this.buildDots();
          this.onScroll();
        }
        onScroll() {
          const active = this.activePage();
          const dots = this.dots?.querySelectorAll('.group-6-products__dot') || [];
          dots.forEach((dot, index) => dot.classList.toggle('is-active', index === active));
        }
      }
      if (!customElements.get('group-6-products-carousel')) {
        customElements.define('group-6-products-carousel', Group6ProductsCarousel);
      }
    })();
  </script>
</section>

{% schema %}
{
  "name": "Group 6 products",
  "settings": [
    { "type": "color_scheme", "id": "color_scheme", "label": "t:settings.color_scheme", "default": "scheme-6" },
    { "type": "text", "id": "pill_label", "label": "Pill label", "default": "Shop by category" },
    { "type": "text", "id": "heading", "label": "t:settings.heading", "default": "Products" },
    { "type": "textarea", "id": "description", "label": "t:settings.description", "default": "Lorem ipsum dolor sit amet, consectetur adipiscing elit. Suspendisse varius enim in eros elementum tristique." },
    { "type": "text", "id": "button_label", "label": "Button label", "default": "Shop Powders" },
    { "type": "url", "id": "button_link", "label": "t:settings.link" },
    { "type": "collection", "id": "collection", "label": "t:settings.collection" },
    { "type": "range", "id": "products_to_show", "label": "Products to show", "min": 4, "max": 12, "step": 1, "default": 8 },
    { "type": "range", "id": "padding-block-start", "min": 0, "max": 120, "step": 4, "unit": "px", "label": "t:settings.top_padding", "default": 24 },
    { "type": "range", "id": "padding-block-end", "min": 0, "max": 120, "step": 4, "unit": "px", "label": "t:settings.bottom_padding", "default": 0 }
  ],
  "presets": [{ "name": "Group 6 products" }]
}
{% endschema %}
